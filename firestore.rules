rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: generations
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user ID who created this generation.
    //   - topic: string (required) - The topic or name of the case.
    //   - scriptStyle: string (required) - The style of the script generated.
    //   - imageryStyle: string (required) - The style of the imagery prompts.
    //   - research: object (required) - The research data.
    //   - script: string (required) - The script content.
    //   - imagePrompts: list (required) - The image prompts.
    //   - createdAt: timestamp (required) - The creation timestamp.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email == "hammedobrien@gmail.com" && request.auth.token.email_verified == true));
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidGeneration(data) {
      let requiredFields = ['uid', 'topic', 'scriptStyle', 'imageryStyle', 'research', 'script', 'imagePrompts', 'createdAt'];
      let optionalFields = ['characterReferenceUrl', 'characterDescription', 'extendedScript', 'extendedImagePrompts', 'seo'];
      let allFields = requiredFields.concat(optionalFields);

      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allFields) &&
             data.uid == request.auth.uid &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 1000 &&
             data.scriptStyle is string &&
             data.imageryStyle is string &&
             data.research is map &&
             data.script is string && data.script.size() > 0 &&
             data.imagePrompts is list &&
             data.createdAt is timestamp &&
             (!('characterReferenceUrl' in data) || data.characterReferenceUrl == null || (data.characterReferenceUrl is string && data.characterReferenceUrl.size() < 2000)) &&
             (!('characterDescription' in data) || data.characterDescription is string) &&
             (!('extendedScript' in data) || data.extendedScript is string) &&
             (!('extendedImagePrompts' in data) || data.extendedImagePrompts is list) &&
             (!('seo' in data) || data.seo is map);
    }

    function isValidContentStyle(data) {
      let requiredFields = ['uid', 'name', 'prompt', 'createdAt'];
      let optionalFields = ['isDefault'];
      let allFields = requiredFields.concat(optionalFields);

      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allFields) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() < 5000 &&
             data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      let requiredFields = ['uid', 'updatedAt'];
      let optionalFields = ['visualStorytellingRules', 'activeVisualPresetId'];
      let allFields = requiredFields.concat(optionalFields);

      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allFields) &&
             data.uid == request.auth.uid &&
             (!('visualStorytellingRules' in data) || (data.visualStorytellingRules is string && data.visualStorytellingRules.size() < 10000)) &&
             (!('activeVisualPresetId' in data) || (data.activeVisualPresetId is string && data.activeVisualPresetId.size() < 100)) &&
             data.updatedAt is timestamp;
    }

    function isValidVisualPreset(data) {
      let requiredFields = ['uid', 'name', 'prompt', 'isActive', 'createdAt'];
      let optionalFields = ['updatedAt'];
      let allFields = requiredFields.concat(optionalFields);

      return data.keys().hasAll(requiredFields) &&
             data.keys().hasOnly(allFields) &&
             data.uid == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.prompt is string && data.prompt.size() > 0 && data.prompt.size() < 10000 &&
             data.isActive is bool &&
             data.createdAt is timestamp &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /generations/{generationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidGeneration(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || isDocOwner()) && isValidGeneration(request.resource.data);
      allow delete: if isAdmin() || isDocOwner();
    }

    match /contentStyles/{styleId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.uid == request.auth.uid);
      allow create: if isAuthenticated() && isValidContentStyle(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || isDocOwner()) && isValidContentStyle(request.resource.data);
      allow delete: if isAdmin() || isDocOwner();
    }

    match /settings/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidSettings(request.resource.data);
      allow update: if isOwner(userId) && isValidSettings(request.resource.data);
      allow delete: if isOwner(userId) || isAdmin();
    }

    match /visualPresets/{presetId} {
      allow read: if isOwner(resource.data.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidVisualPreset(request.resource.data);
      allow update: if isAuthenticated() && (isAdmin() || isDocOwner()) && isValidVisualPreset(request.resource.data);
      allow delete: if isAdmin() || isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
